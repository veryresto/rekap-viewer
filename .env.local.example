# Rekap Viewer Local Development Environment
# Copy this file to .env for local testing

# Google Sheets Configuration
GOOGLE_API_KEY="your-google-api-key"
SHEET_ID="your-google-sheet-id"
RANGE="Import!A1:ZZ550"

# Tigris Storage Configuration (Fly.io Object Storage)
AWS_REGION="auto"
AWS_SECRET_ACCESS_KEY="your-tigris-secret-key"
AWS_ACCESS_KEY_ID="your-tigris-access-key-id"
AWS_ENDPOINT_URL_S3="https://fly.storage.tigris.dev"
BUCKET_NAME="your-tigris-bucket-name"

# Authentication (Veryresto Identity Protocol)
# Point this to the same Supabase project your local portal is using.
SUPABASE_URL="https://lfxkabhzfgenpqfnhjyw.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"

# For local development, point back to the local portal instance
PORTAL_URL="http://community.localtest.me:5173"

# Set to true to completely bypass authentication for local UI testing
# (This skips cookie verification and governance checks entirely)
DEV_BYPASS_AUTH="false"
