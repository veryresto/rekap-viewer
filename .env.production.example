# Rekap Viewer Production Environment Reference
# 
# IMPORTANT: For Fly.io production, do NOT upload a .env file.
# Instead, set these securely using the Fly CLI:
# fly secrets set KEY="value" ANOTHER_KEY="value"

# Google Sheets Configuration
GOOGLE_API_KEY="your-production-google-api-key"
SHEET_ID="your-production-google-sheet-id"
RANGE="Import!A1:ZZ550"

# Tigris Storage Configuration
# Note: These are automatically injected by Fly.io if you provisioned 
# Tigris using `fly storage create` and attached it to the app.
AWS_REGION="auto"
AWS_SECRET_ACCESS_KEY="auto-injected-by-fly"
AWS_ACCESS_KEY_ID="auto-injected-by-fly"
AWS_ENDPOINT_URL_S3="https://fly.storage.tigris.dev"
BUCKET_NAME="auto-injected-by-fly"

# Authentication (Veryresto Identity Protocol)
# Use your production Supabase project details here
SUPABASE_URL="https://vktepgjsiydfdojqbarg.supabase.co"
SUPABASE_ANON_KEY="your-production-supabase-anon-key"

# In production, redirect unauthenticated users to the live portal
PORTAL_URL="https://community.veryresto.com"

# SECURITY: This MUST be false or omitted in production.
DEV_BYPASS_AUTH="false"
